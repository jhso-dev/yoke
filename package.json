{
  "name": "yoke",
  "version": "0.1.0",
  "description": "Ontology-based knowledge DB — governed context injection for AI agents",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jhso-dev/yoke.git"
  },
  "keywords": [
    "knowledge",
    "ontology",
    "mcp",
    "context-injection",
    "ai-agent",
    "sqlite"
  ],
  "bin": {
    "yoke": "dist/front/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "eval": "tsx eval/inject-quality.ts",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.2.0",
    "sqlite-vec": "^0.1.9",
    "ulid": "^3.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.10",
    "tsx": "^4.23.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
